, setLoading] = useState(false);\r\n  const dispatch = useDispatch();\r\n  const navigate = useNavigate();\r\n\r\n  const handleSubmit = async (e) => {\r\n    e.preventDefault();\r\n    setError(\"\");\r\n    setLoading(true);\r\n    try {\r\n      const response = await fetch(\"/backend/api/auth/login.php\", {\r\n        method: \"POST\",\r\n        headers: {\r\n          \"Content-Type\": \"application/json\",\r\n        },\r\n        credentials: \"include\", // ­ƒöÑ REQUIRED\r\n        body: JSON.stringify({\r\n          email,\r\n          password,\r\n          is_admin: false,\r\n        }),\r\n      });\r\n\r\n      const result = await response.json();\r\n\r\n      if (!response.ok) {\r\n        throw new Error(result.message || \"Invalid email or password\");\r\n      }\r\n\r\n      const userData = result.data;\r\n\r\n      // Add user to users slice\r\n      dispatch(addUser({\r\n        id: userData.id.toString(),\r\n        email: userData.email,\r\n        role: userData.role,\r\n      }));\r\n\r\n      // Set auth user\r\n      dispatch(setAuthUser({\r\n        id: userData.id.toString(),\r\n        email: userData.email,\r\n        role: userData.role,\r\n      }));\r\n\r\n      // Redirect based on role\r\n      setTimeout(() => {\r\n        if (userData.role === \"admin\") {\r\n          navigate(\"/admin\", { replace: true });\r\n        } else {\r\n          navigate(\"/\", { replace: true });\r\n        }\r\n      }, 200);\r\n\r\n    } catch (err) {\r\n      setError(err.message || \"Invalid email or password\");\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n\r\n  return (\r\n    <div className=\"container\" style={{ maxWidth: \"500px\", marginTop: \"60px\" }}>\r\n      <div style={{ \r\n        background: \"var(--card)\", \r\n        padding: \"40px\", \r\n        borderRadius: \"14px\",\r\n        border: \"1px solid var(--border)\",\r\n        boxShadow: \"0 8px 20px rgba(0, 0, 0, 0.04)\"\r\n      }}>\r\n        <h1 style={{ marginBottom: \"8px\", fontSize: \"28px\", fontWeight: \"700\" }}>\r\n          User Login\r\n        </h1>\r\n        <p style={{ color: \"var(--muted)\", marginBottom: \"32px\", fontSize: \"15px\" }}>\r\n          Sign in to your account to post ads\r\n        </p>\r\n\r\n        {error && (\r\n          <div style={{\r\n            background: \"#fee2e2\",\r\n            color: \"#dc2626\",\r\n            padding: \"12px\",\r\n            borderRadius: \"8px\",\r\n            marginBottom: \"20px\",\r\n            fontSize: \"14px\"\r\n          }}>\r\n            {error}\r\n          </div>\r\n        )}\r\n\r\n        <form onSubmit={handleSubmit}>\r\n          <div style={{ marginBottom: \"20px\" }}>\r\n            <label style={{ \r\n              display: \"block\", \r\n              marginBottom: \"8px\", \r\n              fontSize: \"14px\", \r\n              fontWeight: \"500\",\r\n              color: \"var(--text)\"\r\n            }}>\r\n              Email\r\n            </label>\r\n            <input\r\n              type=\"email\"\r\n              value={email}\r\n              onChange={(e) => setEmail(e.target.value)}\r\n              required\r\n              className=\"input\"\r\n              style={{ width: \"100%\" }}\r\n              placeholder=\"your@email.com\"\r\n            />\r\n          </div>\r\n\r\n          <div style={{ marginBottom: \"24px\" }}>\r\n            <label style={{ \r\n              display: \"block\", \r\n              marginBottom: \"8px\", \r\n              fontSize: \"14px\", \r\n              fontWeight: \"500\",\r\n              color: \"var(--text)\"\r\n            }}>\r\n              Password\r\n            </label>\r\n            <input\r\n              type=\"password\"\r\n              value={password}\r\n              onChange={(e) => setPassword(e.target.value)}\r\n              required\r\n              className=\"input\"\r\n              style={{ width: \"100%\" }}\r\n              placeholder=\"ÔÇóÔÇóÔÇóÔÇóÔÇóÔÇóÔÇóÔÇó\"\r\n            />\r\n          </div>\r\n\r\n          <button \r\n            type=\"submit\" \r\n            className=\"btn\" \r\n            style={{ width: \"100%\" }}\r\n            disabled={loading}\r\n          >\r\n            {loading ? \"Signing in...\" : \"Sign In\"}\r\n          </button>\r\n        </form>\r\n\r\n        <p style={{ \r\n          marginTop: \"24px\", \r\n          textAlign: \"center\", \r\n          fontSize: \"14px\", \r\n          color: \"var(--muted)\" \r\n        }}>\r\n          Don't have an account?{\" \"}\r\n          <a href=\"/inscription\" style={{ color: \"var(--primary)\", fontWeight: \"500\" }}>\r\n            Register here\r\n          </a>\r\n        </p>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Dell PC\\Documents\\QuickAnnonceReactJS\\quickannonce\\src\\pages\\auth\\Inscription.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Dell PC\\Documents\\QuickAnnonceReactJS\\quickannonce\\src\\pages\\user\\AnnonceDetail.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Dell PC\\Documents\\QuickAnnonceReactJS\\quickannonce\\src\\pages\\user\\Home.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Dell PC\\Documents\\QuickAnnonceReactJS\\quickannonce\\src\\pages\\user\\Publier.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'user' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":13,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":13,"endColumn":13,"suggestions":[{"messageId":"removeVar","data":{"varName":"user"},"fix":{"range":[583,624],"text":""},"desc":"Remove unused variable 'user'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'uploadError' is defined but never used.","line":67,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":67,"endColumn":29}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState } from \"react\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\nimport { useNavigate } from \"react-router-dom\";\r\nimport { addAnnonce, setAnnonces } from \"../../features/annonces/annoncesSlice\";\r\nimport { selectAuthUser } from \"../../features/auth/authSlice\";\r\nimport { createAd } from \"../../services/api/adsService\";\r\nimport { uploadImages } from \"../../services/api/uploadService\";\r\nimport { fetchAds } from \"../../services/api/adsService\";\r\n\r\nexport default function Publier() {\r\n  const dispatch = useDispatch();\r\n  const navigate = useNavigate();\r\n  const user = useSelector(selectAuthUser);\r\n  const [loading, setLoading] = useState(false);\r\n  const [selectedImages, setSelectedImages] = useState([]);\r\n  const [error, setError] = useState(\"\");\r\n\r\n  const handleImageChange = (e) => {\r\n    const files = Array.from(e.target.files);\r\n    // Limit to 5 images\r\n    if (files.length > 5) {\r\n      setError(\"Maximum 5 images allowed\");\r\n      return;\r\n    }\r\n    setSelectedImages(files);\r\n    setError(\"\");\r\n  };\r\n\r\n  const handleSubmit = async (e) => {\r\n    e.preventDefault();\r\n    setError(\"\");\r\n    setLoading(true);\r\n\r\n    try {\r\n      const form = e.target;\r\n\r\n      // Validate required fields\r\n      if (!form.titre.value.trim()) {\r\n        setError(\"Title is required\");\r\n        setLoading(false);\r\n        return;\r\n      }\r\n\r\n      if (!form.typeAnnonce.value) {\r\n        setError(\"Type is required\");\r\n        setLoading(false);\r\n        return;\r\n      }\r\n\r\n      if (!form.prix.value || Number(form.prix.value) <= 0) {\r\n        setError(\"Valid price is required\");\r\n        setLoading(false);\r\n        return;\r\n      }\r\n\r\n      if (!form.ville.value.trim()) {\r\n        setError(\"City is required\");\r\n        setLoading(false);\r\n        return;\r\n      }\r\n\r\n      // Upload images if any\r\n      let imageUrls = [];\r\n      if (selectedImages.length > 0) {\r\n        try {\r\n          imageUrls = await uploadImages(selectedImages);\r\n        } catch (uploadError) {\r\n          setError(\"Failed to upload images. Please try again.\");\r\n          setLoading(false);\r\n          return;\r\n        }\r\n      }\r\n\r\n      // Prepare ad data for PHP API\r\n      const adData = {\r\n        title: form.titre.value.trim(),\r\n        description: form.description.value.trim() || null,\r\n        typeAnnonce: form.typeAnnonce.value,\r\n        category: form.categorie?.value || null,\r\n        subcategory: form.sousCategorie?.value || null,\r\n        price: Number(form.prix.value),\r\n        city: form.ville.value.trim(),\r\n        images: imageUrls,\r\n      };\r\n\r\n      // Save to PHP API\r\n      const newAd = await createAd(adData);\r\n\r\n      // Update Redux with new ad (transform PHP API format to Redux format)\r\n      const reduxAd = {\r\n        id: newAd.id.toString(),\r\n        titre: newAd.title,\r\n        description: newAd.description,\r\n        typeAnnonce: newAd.type_annonce,\r\n        categorieId: newAd.category,\r\n        sousCategorieId: newAd.subcategory,\r\n        prix: parseFloat(newAd.price),\r\n        ville: newAd.city,\r\n        photos: newAd.images || [],\r\n        userId: newAd.user_id.toString(),\r\n        etat: newAd.status === \"pending\" ? \"en_attente\" : newAd.status === \"accepted\" ? \"acceptee\" : \"refusee\",\r\n        datePoster: newAd.created_at,\r\n      };\r\n\r\n      dispatch(addAnnonce(reduxAd));\r\n\r\n      // Refresh ads list from PHP API\r\n      const allAds = await fetchAds();\r\n      const reduxAds = allAds.map((ad) => ({\r\n        id: ad.id.toString(),\r\n        titre: ad.title,\r\n        description: ad.description,\r\n        typeAnnonce: ad.type_annonce,\r\n        categorieId: ad.category,\r\n        sousCategorieId: ad.subcategory,\r\n        prix: parseFloat(ad.price),\r\n        ville: ad.city,\r\n        photos: ad.images || [],\r\n        userId: ad.user_id.toString(),\r\n        etat: ad.status === \"pending\" ? \"en_attente\" : ad.status === \"accepted\" ? \"acceptee\" : \"refusee\",\r\n        datePoster: ad.created_at,\r\n      }));\r\n      dispatch(setAnnonces(reduxAds));\r\n\r\n      form.reset();\r\n      setSelectedImages([]);\r\n      alert(\"Annonce submitted successfully! It's pending admin approval.\");\r\n      navigate(\"/\");\r\n    } catch (err) {\r\n      console.error(\"Error creating ad:\", err);\r\n      setError(err.message || \"Failed to create ad. Please try again.\");\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <main className=\"container\" style={{ padding: \"60px 0\", maxWidth: \"700px\" }}>\r\n      <div style={{\r\n        background: \"var(--card)\",\r\n        padding: \"40px\",\r\n        borderRadius: \"14px\",\r\n        border: \"1px solid var(--border)\",\r\n        boxShadow: \"0 8px 20px rgba(0, 0, 0, 0.04)\"\r\n      }}>\r\n        <h1 style={{ \r\n          fontSize: \"32px\", \r\n          fontWeight: \"700\", \r\n          marginBottom: \"8px\" \r\n        }}>\r\n          Publish an Announcement\r\n        </h1>\r\n        <p style={{ \r\n          color: \"var(--muted)\", \r\n          marginBottom: \"32px\",\r\n          fontSize: \"15px\"\r\n        }}>\r\n          Fill in the details below to create your ad\r\n        </p>\r\n\r\n        {error && (\r\n          <div style={{\r\n            background: \"#fee2e2\",\r\n            color: \"#dc2626\",\r\n            padding: \"12px\",\r\n            borderRadius: \"8px\",\r\n            marginBottom: \"20px\",\r\n            fontSize: \"14px\"\r\n          }}>\r\n            {error}\r\n          </div>\r\n        )}\r\n\r\n        <form onSubmit={handleSubmit}>\r\n          <div style={{ marginBottom: \"20px\" }}>\r\n            <label style={{ \r\n              display: \"block\", \r\n              marginBottom: \"8px\", \r\n              fontSize: \"14px\", \r\n              fontWeight: \"500\",\r\n              color: \"var(--text)\"\r\n            }}>\r\n              Title *\r\n            </label>\r\n            <input\r\n              name=\"titre\"\r\n              type=\"text\"\r\n              required\r\n              className=\"input\"\r\n              style={{ width: \"100%\" }}\r\n              placeholder=\"e.g., Apartment for rent in Casablanca\"\r\n            />\r\n          </div>\r\n\r\n          <div style={{ marginBottom: \"20px\" }}>\r\n            <label style={{ \r\n              display: \"block\", \r\n              marginBottom: \"8px\", \r\n              fontSize: \"14px\", \r\n              fontWeight: \"500\",\r\n              color: \"var(--text)\"\r\n            }}>\r\n              Description\r\n            </label>\r\n            <textarea\r\n              name=\"description\"\r\n              rows=\"5\"\r\n              className=\"input\"\r\n              style={{ width: \"100%\", resize: \"vertical\" }}\r\n              placeholder=\"Describe your item or service in detail...\"\r\n            />\r\n          </div>\r\n\r\n          <div style={{ marginBottom: \"20px\" }}>\r\n            <label style={{ \r\n              display: \"block\", \r\n              marginBottom: \"8px\", \r\n              fontSize: \"14px\", \r\n              fontWeight: \"500\",\r\n              color: \"var(--text)\"\r\n            }}>\r\n              Category\r\n            </label>\r\n            <select\r\n              name=\"categorie\"\r\n              className=\"input\"\r\n              style={{ width: \"100%\" }}\r\n            >\r\n              <option value=\"\">Select category (optional)</option>\r\n              <option value=\"vehicles\">­ƒÜù Vehicles</option>\r\n              <option value=\"real-estate\">­ƒÅá Real Estate</option>\r\n              <option value=\"electronics\">­ƒÆ╗ Electronics</option>\r\n              <option value=\"clothing\">­ƒæù Clothing</option>\r\n              <option value=\"jobs\">­ƒºæÔÇì­ƒÆ╝ Jobs</option>\r\n            </select>\r\n          </div>\r\n\r\n          <div style={{ marginBottom: \"20px\" }}>\r\n            <label style={{ \r\n              display: \"block\", \r\n              marginBottom: \"8px\", \r\n              fontSize: \"14px\", \r\n              fontWeight: \"500\",\r\n              color: \"var(--text)\"\r\n            }}>\r\n              Type *\r\n            </label>\r\n            <select\r\n              name=\"typeAnnonce\"\r\n              required\r\n              className=\"input\"\r\n              style={{ width: \"100%\" }}\r\n            >\r\n              <option value=\"\">Select type</option>\r\n              <option value=\"vente\">Sale</option>\r\n              <option value=\"location\">Rental</option>\r\n              <option value=\"service\">Service</option>\r\n            </select>\r\n          </div>\r\n\r\n          <div style={{ display: \"grid\", gridTemplateColumns: \"1fr 1fr\", gap: \"20px\", marginBottom: \"20px\" }}>\r\n            <div>\r\n              <label style={{ \r\n                display: \"block\", \r\n                marginBottom: \"8px\", \r\n                fontSize: \"14px\", \r\n                fontWeight: \"500\",\r\n                color: \"var(--text)\"\r\n              }}>\r\n                Price (MAD) *\r\n              </label>\r\n              <input\r\n                name=\"prix\"\r\n                type=\"number\"\r\n                required\r\n                min=\"0\"\r\n                step=\"0.01\"\r\n                className=\"input\"\r\n                style={{ width: \"100%\" }}\r\n                placeholder=\"0\"\r\n              />\r\n            </div>\r\n\r\n            <div>\r\n              <label style={{ \r\n                display: \"block\", \r\n                marginBottom: \"8px\", \r\n                fontSize: \"14px\", \r\n                fontWeight: \"500\",\r\n                color: \"var(--text)\"\r\n              }}>\r\n                City *\r\n              </label>\r\n              <input\r\n                name=\"ville\"\r\n                type=\"text\"\r\n                required\r\n                className=\"input\"\r\n                style={{ width: \"100%\" }}\r\n                placeholder=\"e.g., Casablanca\"\r\n              />\r\n            </div>\r\n          </div>\r\n\r\n          <div style={{ marginBottom: \"24px\" }}>\r\n            <label style={{ \r\n              display: \"block\", \r\n              marginBottom: \"8px\", \r\n              fontSize: \"14px\", \r\n              fontWeight: \"500\",\r\n              color: \"var(--text)\"\r\n            }}>\r\n              Images (up to 5)\r\n            </label>\r\n            <input\r\n              type=\"file\"\r\n              accept=\"image/*\"\r\n              multiple\r\n              onChange={handleImageChange}\r\n              className=\"input\"\r\n              style={{ width: \"100%\", padding: \"8px\" }}\r\n            />\r\n            {selectedImages.length > 0 && (\r\n              <div style={{ marginTop: \"12px\", display: \"flex\", gap: \"8px\", flexWrap: \"wrap\" }}>\r\n                {selectedImages.map((file, index) => (\r\n                  <div key={index} style={{\r\n                    position: \"relative\",\r\n                    width: \"80px\",\r\n                    height: \"80px\",\r\n                    borderRadius: \"8px\",\r\n                  